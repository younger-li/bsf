# 生成Excel报表
def generate_excel(data, headers, filename):
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = '数据报表'
    # 写入表头
    ws.append(headers)
    # 写入数据
    for row in data:
        ws.append(row)
    # 保存文件
    file_path = f'static/{filename}.xlsx'
    wb.save(file_path)
    return file_path

# 生成趋势图表（Plotly）
def generate_chart(data, x_col, y_col, title, chart_type='line'):
    if chart_type == 'line':
        fig = px.line(data, x=x_col, y=y_col, title=title)
    elif chart_type == 'bar':
        fig = px.bar(data, x=x_col, y=y_col, title=title)
    # 转为JSON
    graph_json = json.dumps(fig, cls=plotly.utils.PlotlyJSONEncoder)
    return graph_json

# 获取当月统计数据
def get_month_stats():
    # 本月起始和结束日期
    today = date.today()
    month_start = date(today.year, today.month, 1)
    # 1. 本月种虫产出总量
    larva_out_total = db.session.query(func.sum(BreedingLarvaOut.out_quantity)).filter(
        BreedingLarvaOut.out_date >= month_start
    ).scalar() or 0
    # 2. 本月虫卵产出总量
    egg_produce_total = db.session.query(func.sum(EggProduce.produce_quantity)).filter(
        EggProduce.produce_date >= month_start
    ).scalar() or 0
    # 3. 本月虫卵销售总量
    egg_sale_total = db.session.query(func.sum(EggSale.sale_quantity)).filter(
        EggSale.sale_date >= month_start
    ).scalar() or 0
    return {
        'larva_out_total': round(float(larva_out_total), 2),
        'egg_produce_total': round(float(egg_produce_total), 2),
        'egg_sale_total': round(float(egg_sale_total), 2)
    }

# 获取趋势数据（近7天/30天）
def get_trend_data(days=7):
    end_date = date.today()
    start_date = end_date - timedelta(days=days-1)
    # 养殖趋势：每日种虫产出
    larva_trend = db.session.query(
        BreedingLarvaOut.out_date,
        func.sum(BreedingLarvaOut.out_quantity).label('total')
    ).filter(
        BreedingLarvaOut.out_date >= start_date,
        BreedingLarvaOut.out_date <= end_date
    ).group_by(BreedingLarvaOut.out_date).order_by(BreedingLarvaOut.out_date).all()
    # 孵化趋势：每日虫卵产出
    egg_trend = db.session.query(
        EggProduce.produce_date,
        func.sum(EggProduce.produce_quantity).label('total')
    ).filter(
        EggProduce.produce_date >= start_date,
        EggProduce.produce_date <= end_date
    ).group_by(EggProduce.produce_date).order_by(EggProduce.produce_date).all()
    # 格式化数据
    larva_data = [{'date': str(item[0]), 'total': round(float(item[1]), 2)} for item in larva_trend]
    egg_data = [{'date': str(item[0]), 'total': round(float(item[1]), 2)} for item in egg_trend]
    return {'larva_trend': larva_data, 'egg_trend': egg_data}

