@login_required
def raw_out_manage():
    if current_user.role != 1:
        return jsonify({'code': 403, 'msg': '无操作权限'})
    if request.method == 'POST':
        # 新增出料记录
        data = request.get_json()
        pool_id = data.get('pool_id')
        out_date = data.get('out_date')
        out_quantity = data.get('out_quantity')
        breeding_pool_code = data.get('breeding_pool_code')
        operator = data.get('operator')
        if not all([pool_id, out_date, out_quantity, breeding_pool_code, operator]):
            return jsonify({'code': 400, 'msg': '请填写完整信息'})
        if float(out_quantity) <= 0:
            return jsonify({'code': 400, 'msg': '出料数量必须大于0'})
        # 转换日期
        out_date = datetime.strptime(out_date, '%Y-%m-%d').date()
        # 获取原料池
        pool = RawMaterialPool.query.get(pool_id)
        if not pool:
            return jsonify({'code': 404, 'msg': '原料池不存在'})
        # 校验库存
        if pool.current_stock < float(out_quantity):
            return jsonify({'code': 400, 'msg': f'库存不足，当前库存{pool.current_stock}公斤'})
        # 校验养殖池是否存在
        if not BreedingPool.query.filter_by(code=breeding_pool_code).first():
            return jsonify({'code': 404, 'msg': '分配的养殖池不存在'})
        # 创建记录
        out_rec = RawMaterialOut(
            pool_id=pool_id,
            out_date=out_date,
            out_quantity=out_quantity,
            breeding_pool_code=breeding_pool_code,
            operator=operator
        )
        db.session.add(out_rec)
        # 更新库存
        pool.current_stock -= float(out_quantity)
        add_sys_log(current_user.id, current_user.phone, '新增', f'原料池{pool.name}出料{out_quantity}公斤至养殖池{breeding_pool_code}', '成功')
        db.session.commit()
        return jsonify({'code': 200, 'msg': '出料记录新增成功，库存已更新'})
    elif request.method == 'DELETE':
        # 删除出料记录
        rid = request.args.get('id')
        out_rec = RawMaterialOut.query.get(rid)
        if not out_rec:
            return jsonify({'code': 404, 'msg': '出料记录不存在'})
