@app.route('/api/raw_in', methods=['POST', 'DELETE'])
@login_required
def raw_in_manage():
    if current_user.role != 1:
        return jsonify({'code': 403, 'msg': '无操作权限'})
    if request.method == 'POST':
        # 新增进料记录
        data = request.get_json()
        pool_id = data.get('pool_id')
        in_date = data.get('in_date')
        in_quantity = data.get('in_quantity')
        source = data.get('source')
        operator = data.get('operator')
        if not all([pool_id, in_date, in_quantity, source, operator]):
            return jsonify({'code': 400, 'msg': '请填写完整信息'})
        if float(in_quantity) <= 0:
            return jsonify({'code': 400, 'msg': '进料数量必须大于0'})
        # 转换日期
        in_date = datetime.strptime(in_date, '%Y-%m-%d').date()
        # 获取原料池
        pool = RawMaterialPool.query.get(pool_id)
        if not pool:
            return jsonify({'code': 404, 'msg': '原料池不存在'})
        # 创建记录
        in_rec = RawMaterialIn(
            pool_id=pool_id,
            in_date=in_date,
            in_quantity=in_quantity,
            source=source,
            operator=operator
        )
        db.session.add(in_rec)
        # 更新库存
        pool.current_stock += float(in_quantity)
        add_sys_log(current_user.id, current_user.phone, '新增', f'原料池{pool.name}进料{in_quantity}公斤', '成功')
        db.session.commit()
        return jsonify({'code': 200, 'msg': '进料记录新增成功，库存已更新'})
    elif request.method == 'DELETE':
        # 删除进料记录
        rid = request.args.get('id')
        in_rec = RawMaterialIn.query.get(rid)
        if not in_rec:
            return jsonify({'code': 404, 'msg': '进料记录不存在'})
        # 检查是否为当天记录
        if in_rec.in_date != date.today():
            return jsonify({'code': 400, 'msg': '仅可删除当天的进料记录'})
        # 更新库存
        pool = RawMaterialPool.query.get(in_rec.pool_id)
        pool.current_stock -= float(in_rec.in_quantity)
        # 删除记录
        add_sys_log(current_user.id, current_user.phone, '删除', f'删除原料池{pool.name}进料记录{in_rec.in_quantity}公斤', '成功')
        db.session.delete(in_rec)
        db.session.commit()
        return jsonify({'code': 200, 'msg': '进料记录删除成功，库存已回滚'})

