@app.route('/api/raw_pool', methods=['POST', 'PUT', 'DELETE'])
@login_required
def raw_pool_manage():
    if current_user.role != 1:
        return jsonify({'code': 403, 'msg': '无操作权限'})
    if request.method == 'POST':
        # 新增原料池
        data = request.get_json()
        name = data.get('name')
        volume = data.get('volume')
        material_type = data.get('material_type')
        location = data.get('location')
        min_stock = data.get('min_stock', 0)
        # 校验
        if not all([name, volume, material_type, location]):
            return jsonify({'code': 400, 'msg': '请填写完整信息'})
        if RawMaterialPool.query.filter_by(name=name).first():
            return jsonify({'code': 400, 'msg': '原料池名称已存在'})
        # 创建
        pool = RawMaterialPool(
            name=name,
            volume=volume,
            material_type=material_type,
            location=location,
            min_stock=min_stock
        )
        db.session.add(pool)
        add_sys_log(current_user.id, current_user.phone, '新增', f'新增原料池：{name}', '成功')
        db.session.commit()
        return jsonify({'code': 200, 'msg': '新增成功'})
    elif request.method == 'PUT':
        # 编辑原料池
        data = request.get_json()
        pid = data.get('id')
        name = data.get('name')
        volume = data.get('volume')
        material_type = data.get('material_type')
        location = data.get('location')
        min_stock = data.get('min_stock', 0)
        pool = RawMaterialPool.query.get(pid)
        if not pool:
            return jsonify({'code': 404, 'msg': '原料池不存在'})
        # 校验名称唯一性（排除自身）
        if RawMaterialPool.query.filter(RawMaterialPool.name == name, RawMaterialPool.id != pid).first():
            return jsonify({'code': 400, 'msg': '原料池名称已存在'})
        # 更新
        pool.name = name
        pool.volume = volume
        pool.material_type = material_type
        pool.location = location
        pool.min_stock = min_stock
        add_sys_log(current_user.id, current_user.phone, '编辑', f'编辑原料池：{pool.name}', '成功')
        db.session.commit()
        return jsonify({'code': 200, 'msg': '编辑成功'})
    elif request.method == 'DELETE':
        # 删除原料池
        pid = request.args.get('id')
        pool = RawMaterialPool.query.get(pid)
        if not pool:
            return jsonify({'code': 404, 'msg': '原料池不存在'})
        # 检查是否有历史记录
        if RawMaterialIn.query.filter_by(pool_id=pid).first() or RawMaterialOut.query.filter_by(pool_id=pid).first():
            return jsonify({'code': 400, 'msg': '该原料池存在历史数据，无法删除'})
        # 删除
        add_sys_log(current_user.id, current_user.phone, '删除', f'删除原料池：{pool.name}', '成功')
        db.session.delete(pool)
        db.session.commit()
        return jsonify({'code': 200, 'msg': '删除成功'})

