# 注册接口
@app.route('/api/register', methods=['POST'])
def register():
    data = request.get_json()
    phone = data.get('phone')
    password = data.get('password')
    # 数据校验
    if not phone or len(phone) != 11 or not phone.isdigit():
        return jsonify({'code': 400, 'msg': '请输入正确的11位手机号'})
    if not password or len(password) < 6 or len(password) > 18:
        return jsonify({'code': 400, 'msg': '密码长度需为6-18位'})
    # 检查手机号是否已注册
    if User.query.filter_by(phone=phone).first():
        return jsonify({'code': 400, 'msg': '该手机号已注册'})
    # 判断是否为初始管理员
    role = 1 if phone == ADMIN_DEFAULT_PHONE else 0
    # 创建用户
    user = User(
        phone=phone,
        password=md5_encrypt(password),
        role=role
    )
    db.session.add(user)
    # 记录日志
    add_sys_log(user.id, phone, '注册', f'用户{phone}完成注册，权限：{"管理员" if role==1 else "普通用户"}', '成功')
    db.session.commit()
    return jsonify({'code': 200, 'msg': '注册成功，请登录'})

