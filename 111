@app.route('/api/login', methods=['POST'])
def do_login():
    data = request.get_json()
    phone = data.get('phone')
    password = data.get('password')
    # 数据校验
    if not phone or not password:
        return jsonify({'code': 400, 'msg': '手机号和密码不能为空'})
    # 查找用户
    user = User.query.filter_by(phone=phone).first()
    if not user:
        return jsonify({'code': 401, 'msg': '手机号未注册'})
    # 检查账号是否锁定
    if user.login_lock_time and user.login_lock_time > datetime.now():
        remain = (user.login_lock_time - datetime.now()).seconds // 60
        return jsonify({'code': 401, 'msg': f'账号已锁定，剩余{remain}分钟解锁'})
    # 校验密码
    if user.password != md5_encrypt(password):
        user.login_fail_count += 1
        # 失败5次锁定1小时
        if user.login_fail_count >= 5:
            user.login_lock_time = datetime.now() + timedelta(hours=1)
            user.login_fail_count = 0
            db.session.commit()
            add_sys_log(user.id, phone, '登录', f'用户{phone}登录失败5次，账号锁定1小时', '失败')
            return jsonify({'code': 401, 'msg': '登录失败次数过多，账号锁定1小时'})
        db.session.commit()
        add_sys_log(user.id, phone, '登录', f'用户{phone}登录失败，密码错误，失败次数：{user.login_fail_count}', '失败')
        return jsonify({'code': 401, 'msg': f'密码错误，剩余{5-user.login_fail_count}次尝试'})
    # 登录成功，重置失败次数
    user.login_fail_count = 0
    db.session.commit()
    login_user(user)
    add_sys_log(user.id, phone, '登录', f'用户{phone}登录成功，权限：{"管理员" if user.role==1 else "普通用户"}', '成功')
    return jsonify({'code': 200, 'msg': '登录成功', 'role': user.role})

